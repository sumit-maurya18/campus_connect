{
  "name": "opportunity-portal-backend",
  "version": "1.0.0",
  "description": "Backend API for Opportunity Portal - Internships, Jobs, Hackathons, Scholarships",
  "main": "src/server.js",
  "scripts": {
    "start": "NODE_ENV=production node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --verbose --forceExit",
    "test:watch": "jest --watch --forceExit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "seed": "node src/utils/seeder.js -i",
    "seed:destroy": "node src/utils/seeder.js -d"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pino": "^9.14.0",
    "pino-pretty": "^11.0.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
